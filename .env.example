# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=your_telegram_id

# Database PostgreSQL
POSTGRES_DB=telegram_bot_db
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Settings
NODE_ENV=production
LOG_LEVEL=info
BATCH_SIZE=25
BATCH_DELAY=1500
